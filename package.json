{
  "name": "media-manager",
  "version": "11.0.0",
  "description": "Media Manager - Grid & Detail View für Videos und Bilder",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build": "electron-builder"
  },
  "keywords": ["video", "media", "manager", "electron"],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0"
  },
  "build": {
    "appId": "com.mediamanager.app",
    "productName": "Media Manager",
    "directories": { "output": "dist" },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}